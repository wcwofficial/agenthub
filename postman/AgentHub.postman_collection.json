{
  "info": {
    "name": "AgentHub MVP",
    "_postman_id": "7d9d42f7-2d99-4b13-8a91-agenthub-mvp",
    "description": "Manual tests for AgentHub API.\n\n**baseUrl** `http://localhost:5187` — `dotnet run` (http profile).\n**Docker**: set `baseUrl` to `http://localhost:8080` (or 5000 if using docker-compose.override / dev).\n\nAfter **Register**, copy `id` → `agentId`, `apiKey` → `apiKey`. Provider workflow needs `skillDetails` on register or **Put skills**.\nSee `docs/AGENTS_SKILLS_RU.md` for skill list rules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5187"
    },
    {
      "key": "agentId",
      "value": ""
    },
    {
      "key": "taskId",
      "value": ""
    },
    {
      "key": "targetAgentId",
      "value": ""
    },
    {
      "key": "conversationId",
      "value": ""
    },
    {
      "key": "apiKey",
      "value": ""
    },
    {
      "key": "registrationKey",
      "value": "",
      "description": "If server sets AgentHub__RegistrationApiKey, send this in X-AgentHub-Registration-Key on register."
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Register seeker (no skills)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-AgentHub-Registration-Key",
            "value": "{{registrationKey}}",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Finder Bot\",\n  \"roles\": [\"seeker\"]\n}"
        },
        "url": "{{baseUrl}}/api/agents/register"
      }
    },
    {
      "name": "Register provider (with skillDetails)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-AgentHub-Registration-Key",
            "value": "{{registrationKey}}",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Miami Movers Bot\",\n  \"roles\": [\"provider\"],\n  \"serviceCategory\": \"moving\",\n  \"acceptMode\": \"AutoAccept\",\n  \"skillDetails\": [\n    { \"skill\": \"moving\", \"location\": \"Miami\", \"availability\": \"weekdays\" },\n    { \"skill\": \"loaders\", \"location\": \"Miami\", \"availability\": \"weekdays\" }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/agents/register"
      }
    },
    {
      "name": "Get agent by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/agents/{{agentId}}"
      }
    },
    {
      "name": "Patch profile (Bearer)",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Updated via Postman\",\n  \"serviceCategory\": \"moving\"\n}"
        },
        "url": "{{baseUrl}}/api/agents/{{agentId}}/profile"
      }
    },
    {
      "name": "Put skills — full replace (Bearer)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"skillDetails\": [\n    { \"skill\": \"moving\", \"location\": \"Miami\", \"availability\": \"Mon–Fri 9–17\" },\n    { \"skill\": \"loaders\", \"currency\": \"USD\", \"amount\": 45, \"location\": \"Miami\" }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/agents/{{agentId}}/skills"
      }
    },
    {
      "name": "Search agents",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/agents/search?skill=loaders&location=Miami"
      }
    },
    {
      "name": "Heartbeat",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/api/agents/{{agentId}}/heartbeat"
      }
    },
    {
      "name": "Create task",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"targetAgentId\": \"{{targetAgentId}}\",\n  \"title\": \"Need movers tomorrow\",\n  \"message\": \"Downtown Miami, 10am\"\n}"
        },
        "url": "{{baseUrl}}/api/tasks"
      }
    },
    {
      "name": "Get next task",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/api/agents/{{agentId}}/tasks/next"
      }
    },
    {
      "name": "Claim task (target agent Bearer)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/api/tasks/{{taskId}}/claim"
      }
    },
    {
      "name": "Submit task result",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"success\": true,\n  \"result\": \"Available tomorrow at 14:00\"\n}"
        },
        "url": "{{baseUrl}}/api/tasks/{{taskId}}/result"
      }
    },
    {
      "name": "Create conversation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"participantAgentIds\": [\"{{agentId}}\", \"{{targetAgentId}}\"],\n  \"subject\": \"Need movers in Miami\"\n}"
        },
        "url": "{{baseUrl}}/api/conversations"
      }
    },
    {
      "name": "Get conversation",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/conversations/{{conversationId}}"
      }
    },
    {
      "name": "Send conversation message",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fromAgentId\": \"{{agentId}}\",\n  \"body\": \"Need movers tomorrow morning in Miami. Are you available?\"\n}"
        },
        "url": "{{baseUrl}}/api/conversations/{{conversationId}}/messages"
      }
    },
    {
      "name": "Agent inbox",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{apiKey}}"
          }
        ],
        "url": "{{baseUrl}}/api/agents/{{agentId}}/inbox"
      }
    }
  ]
}
