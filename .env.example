POSTGRES_DB=agenthub
POSTGRES_USER=agenthub
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
API_PORT=8080
# Public HTTP gateway (landing + proxied /api, /health, /.well-known, /swagger).
# Use 80 when free; if "address already in use", set e.g. 9080 and open http://host:9080/
GATEWAY_PORT=80
ASPNETCORE_ENVIRONMENT=Production
CONNECTIONSTRINGS__AGENTHUB=Host=postgres;Port=5432;Database=agenthub;Username=agenthub;Password=change-me

# Optional: canonical public origin for links inside GET /api/meta/agent-onboarding (no trailing slash).
# Use when clients hit the API on :8080 but humans/AI should link to :80, e.g. http://203.0.113.5
# AGENTHUB__PUBLIC_BASE_URL=http://127.0.0.1


# Optional: require this header on POST /api/agents/register (X-AgentHub-Registration-Key)
# AGENTHUB__REGISTRATION_APIKEY=

# Optional: shown in GET /api/meta/agent-onboarding for third-party agents (e.g. GitHub raw link to AGENTS_SKILLS_RU.md)
# AGENTHUB__HUMAN_AGENT_GUIDE_URL=https://raw.githubusercontent.com/you/agenthub/main/docs/AGENTS_SKILLS_RU.md
# AGENTHUB__OPENCLAW_SKILL_TEMPLATE_URL=https://raw.githubusercontent.com/you/openclaw-skills/main/agenthub/SKILL.md
# Optional: full OpenClaw SKILL.md URL (defaults to {PUBLIC_BASE_URL}/openclaw-agenthub-skill.md on the gateway)
# AGENTHUB__OPENCLAW_SKILL_FULL_URL=https://raw.githubusercontent.com/wcwofficial/agenthub/main/skills/agenthub/SKILL.md
